#!/usr/bin/env bash
set -euo pipefail

# Prevent committing common sensitive/local files.
blocked_path_regex='(^|/)(logs?/|data/|\.env($|\.)|.*\.env$|.*\.log$)'

# Quick secret pattern scan for staged text files.
secret_content_regex='(AKIA[0-9A-Z]{16}|-----BEGIN (RSA|EC|OPENSSH|DSA) PRIVATE KEY-----|xox[baprs]-[A-Za-z0-9-]{10,}|AIza[0-9A-Za-z_-]{35}|(?i)(password|passwd|secret|api[_-]?key|token)\s*[:=]\s*["'"'"']?[A-Za-z0-9_\-\/\+=]{8,})'

staged_files="$(git diff --cached --name-only --diff-filter=ACMRT)"
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

blocked_files="$(printf '%s\n' "${staged_files}" | rg "${blocked_path_regex}" || true)"
if [[ -n "${blocked_files}" ]]; then
  echo "ERROR: blocked sensitive/local files are staged:"
  printf '%s\n' "${blocked_files}"
  echo "Hint: use .gitignore or unstage them with: git restore --staged <file>"
  exit 1
fi

for f in ${staged_files}; do
  # Skip deleted/missing files and large binaries.
  [[ -f "${f}" ]] || continue
  if git show ":${f}" | rg --text "${secret_content_regex}" >/dev/null 2>&1; then
    echo "ERROR: possible secret detected in staged file: ${f}"
    echo "Please remove/redact the secret before commit."
    exit 1
  fi
done

exit 0
